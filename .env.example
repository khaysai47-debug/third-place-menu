# Environment template for Atlas / The Third Place.
# Copy to .env.local for local dev, and set the same three vars in the
# Vercel project settings for deploys. NEVER commit real values.

# n8n Cloud base URL — still REQUIRED after the Phase 2E read flip:
# all writes (status/payment/cancel/order intake/expenses) go through n8n.
VITE_N8N_BASE_URL=https://your-n8n-host.example.com

# Supabase read path (required since Phase 2E — reads come from Supabase).
# Use the anon PUBLIC key ONLY. NEVER the service_role / sb_secret key —
# those live exclusively inside n8n.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Server-only secrets (Phase 2G-D staff write routes) ──────────────────────
# Read via process.env INSIDE server routes only. NEVER prefix these with
# VITE_ (VITE_ values are inlined into the client bundle). Set in .env.local
# for dev and in the hosting project's server env for deploys.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-server-only
STAFF_WRITE_SECRET=your-shared-staff-secret

# ── Phase 3A order-automation bridge (OPTIONAL — leave unset to disable) ─────
# BOTH must be set or the bridge is skipped and orders proceed normally.
# The URL must be a NEW automation-only n8n webhook (NO order insert nodes) —
# NEVER the old third-place-order-test intake webhook (it inserts an order).
# The secret signs the event body with HMAC SHA-256 (x-atlas-signature).
#N8N_ORDER_AUTOMATION_WEBHOOK_URL=https://your-n8n-host.example.com/webhook/your-new-automation-only-path
#N8N_AUTOMATION_SECRET=your-long-random-automation-secret
