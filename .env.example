# Environment template for Atlas / The Third Place.
# Copy to .env.local for local dev, and set the same three vars in the
# Vercel project settings for deploys. NEVER commit real values.

# n8n Cloud base URL — still REQUIRED after the Phase 2E read flip:
# all writes (status/payment/cancel/order intake/expenses) go through n8n.
VITE_N8N_BASE_URL=https://your-n8n-host.example.com

# Supabase read path (required since Phase 2E — reads come from Supabase).
# Use the anon PUBLIC key ONLY. NEVER the service_role / sb_secret key —
# those live exclusively inside n8n.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Server-only secrets (Phase 2G-D staff write routes) ──────────────────────
# Read via process.env INSIDE server routes only. NEVER prefix these with
# VITE_ (VITE_ values are inlined into the client bundle). Set in .env.local
# for dev and in the hosting project's server env for deploys.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-server-only
STAFF_WRITE_SECRET=your-shared-staff-secret

# ── Phase 3A order-automation bridge (OPTIONAL — leave unset to disable) ─────
# BOTH must be set or the bridge is skipped and orders proceed normally.
# Phase 3C: even when set, ONLY server-resolved bot channels (instagram/
# messenger — none producible yet) dispatch; normal customer/staff orders
# never do. Unsetting both remains the global emergency dispatch-off switch.
# The URL must be a NEW automation-only n8n webhook (NO order insert nodes) —
# NEVER the old third-place-order-test intake webhook (it inserts an order).
# The secret signs a short-lived HS256 JWT (Authorization: Bearer) and must
# equal the passphrase of the n8n JWT credential used by the webhook's
# JWT Auth (runbook § Phase 3A).
#N8N_ORDER_AUTOMATION_WEBHOOK_URL=https://your-n8n-host.example.com/webhook/your-new-automation-only-path
#N8N_AUTOMATION_SECRET=your-long-random-automation-secret

# ── Phase 3D secure bot sessions (server-only — NEVER prefix with VITE_) ─────
# Required for /api/automation/bot-session, /api/menu-session/resolve and
# /api/order/submit-session. Until they are set those routes answer safe 500s
# and nothing else changes; normal customer/staff checkout is unaffected.

# Inbound authentication for the trusted simulated chat adapter, sent as the
# x-bot-secret header and compared with timingSafeEqual. DELIBERATELY NOT
# STAFF_WRITE_SECRET: that one lives in staff-device localStorage, so sharing
# it would let any staff device mint bot sessions and would tie its rotation
# to the dashboards.
BOT_SESSION_SECRET=your-long-random-bot-inbound-secret

# HMAC-SHA256 key for DETERMINISTIC secure-link token derivation. MUST be a
# different value from BOT_SESSION_SECRET (different purpose, different blast
# radius, different rotation cadence). Generate with:
#   openssl rand -base64 32
# ⚠️ ROTATION: existing links keep working, but an idempotent RETRY of a
# session created under the old key can no longer reproduce its token and
# fails closed with SESSION_TOKEN_UNRECOVERABLE (never a dead link). Rotate
# only in a window of at least the 24 h session TTL.
# ⚠️ This key plus a database dump makes every LIVE token recomputable
# (request_id is a stored column). That is inherent to "same link on retry" —
# an encrypted-token design has the identical exposure — and is bounded by the
# 24 h TTL and single-use checkout. Server-only; never in n8n; never logged.
BOT_SESSION_TOKEN_SECRET=your-long-random-token-derivation-secret

# Origin used to build the secure link "<PUBLIC_SITE_URL>/m#<token>".
# Preview and Production have different origins — set it per environment.
# Not derived from the request Host header, which is attacker-controllable.
PUBLIC_SITE_URL=https://your-production-domain.example.com

# OPTIONAL public handles for the "Start New Order" return-to-chat action.
# These are PUBLIC values (not secrets) kept server-side so the mapping lives
# in one place. A HANDLE ONLY — never a full URL: the server validates it
# against ^[A-Za-z0-9._]{1,60}$ and interpolates it into a fixed template
# (https://m.me/<handle> or https://ig.me/m/<handle>), so a misconfiguration
# can never redirect customers off-site. Unset or malformed → the UI shows
# generic return-to-chat instructions instead of a broken button.
#MESSENGER_PAGE_HANDLE=yourpagehandle
#INSTAGRAM_HANDLE=your.instagram.handle
